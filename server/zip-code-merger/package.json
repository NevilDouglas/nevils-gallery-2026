{
  "name": "zip-code-merger",
  "version": "1.0.0",
  "description": "Electron GUI tool om client/server code te bundelen",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "Nevil",
  "license": "MIT",
  "devDependencies": {
    "adm-zip": "^0.5.10",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.1"
  },
  "build": {
    "appId": "com.nevil.zipcodemerger",
    "productName": "Zip Code Merger",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
